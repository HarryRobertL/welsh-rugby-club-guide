{
  "name": "cymru-rugby",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "ingest": "ts-node --project tsconfig.ingest.json ingestion/run.ts",
    "ingest:no-cache": "ts-node --project tsconfig.ingest.json ingestion/run.ts --no-cache",
    "ingest:allwalessport": "INGEST_SOURCE=allwalessport ts-node --project tsconfig.ingest.json ingestion/run.ts",
    "test:ingest": "ts-node --project tsconfig.ingest.json ingestion/parsers/mywru/parser.test.ts",
    "test:ingest:allwalessport": "ts-node --project tsconfig.ingest.json ingestion/tests/allwalessport-parser.test.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@supabase/supabase-js": "^2.93.3",
    "cheerio": "^1.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "~19.1.0",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
