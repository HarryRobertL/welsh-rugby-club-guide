{
  "name": "cymru-rugby",
  "version": "1.0.0",
  "description": "Welsh Rugby Club Guide — cross-platform fixtures, competitions, and clubs (Expo, React Native, Supabase). Companion to welshrugbyclubguide.com.",
  "keywords": [
    "expo",
    "expo-router",
    "react-native",
    "react-native-web",
    "supabase",
    "typescript",
    "rugby",
    "wales",
    "fixtures",
    "postgresql",
    "playwright",
    "netlify"
  ],
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "ingest": "ts-node --project tsconfig.ingest.json ingestion/run.ts",
    "ingest:no-cache": "ts-node --project tsconfig.ingest.json ingestion/run.ts --no-cache",
    "ingest:allwalessport": "INGEST_SOURCE=allwalessport ts-node --project tsconfig.ingest.json ingestion/run.ts",
    "ingest:allwalessport:full": "ts-node --project tsconfig.ingest.json ingestion/run-allwalessport-full.ts",
    "test:ingest": "ts-node --project tsconfig.ingest.json ingestion/parsers/mywru/parser.test.ts",
    "test:ingest:allwalessport": "ts-node --project tsconfig.ingest.json ingestion/tests/allwalessport-parser.test.ts",
    "test:e2e": "playwright test e2e/smoke.spec.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.93.3",
    "cheerio": "^1.2.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^10.0.0",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
