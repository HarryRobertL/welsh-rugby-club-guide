# Copy to `.env` and fill in values. Never commit `.env`.

# --- App (Expo / client) — required ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- EAS (optional) — native push notifications / builds ---
# EAS_PROJECT_ID=your-eas-project-id

# --- Ingestion (Node / ts-node only) — never use the service role in the app ---
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ALLOW_LOCAL_SUPABASE=1
# INGEST_SOURCE=mywru
# INGEST_DRY_RUN=1
# DISABLE_CACHE=1
# INGEST_DEBUG_GROUPS=1

# --- All Wales Sport ingestion (optional) ---
# ALLWALESSPORT_ALLOWLIST=
# ALLWALESSPORT_CID=
# ALLWALESSPORT_LIMIT=
# DEBUG_ALLWALESSPORT=1

# --- Six Nations fetch (optional) ---
# SIXNATIONS_USER_AGENT=
# SIXNATIONS_REFERER=
# SIXNATIONS_COOKIE=

# --- Playwright smoke test (`npm run test:e2e`) — test account only ---
# PLAYWRIGHT_SMOKE_EMAIL=you@example.com
# PLAYWRIGHT_SMOKE_PASSWORD=your-test-password
