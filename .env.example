# App (Expo / client) — required for app and web build
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Ingestion (Node only) — required for npm run ingest; never commit the real key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# EAS (optional) — set after running eas init so push notifications work in native builds
# EAS_PROJECT_ID=your-eas-project-id
